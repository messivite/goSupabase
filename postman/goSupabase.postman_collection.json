{
  "info": {
    "_postman_id": "b8e3c0a1-0000-4000-8000-000000000001",
    "name": "goSupaBase API",
    "description": "Sample requests aligned with api.yaml (basePath /api). Set `baseUrl` (e.g. http://localhost:8080) and `accessToken` (Supabase user JWT) for protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "trackId", "value": "replace-with-uuid" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "GET health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        },
        {
          "name": "GET tracks",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/tracks"
          }
        },
        {
          "name": "GET playlists",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/playlists"
          }
        }
      ]
    },
    {
      "name": "Auth (Bearer)",
      "item": [
        {
          "name": "POST tracks",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Example track\"\n}"
            },
            "url": "{{baseUrl}}/api/tracks"
          }
        },
        {
          "name": "PATCH tracks by id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\"\n}"
            },
            "url": "{{baseUrl}}/api/tracks/{{trackId}}"
          }
        },
        {
          "name": "DELETE tracks by id (admin role)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/tracks/{{trackId}}"
          }
        },
        {
          "name": "POST playlists",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My playlist\"\n}"
            },
            "url": "{{baseUrl}}/api/playlists"
          }
        }
      ]
    }
  ]
}
